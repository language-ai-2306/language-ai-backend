{
  "info": {
    "name": "Language AI Backend",
    "description": "Ready-to-run requests. Order: Signup -> Login (auto-saves token) -> everything else.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "doctor_token", "value": "" },
    { "key": "test_id", "value": "" },
    { "key": "prof_responses", "value": "" },
    { "key": "patient_email", "value": "patient1@example.com" },
    { "key": "doctor_email", "value": "doctor1@example.com" },
    { "key": "password", "value": "supersecret123" }
  ],
  "item": [
    {
      "name": "1. Signup Patient",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/auth/signup/patient",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{patient_email}}\",\n  \"password\": \"{{password}}\",\n  \"first_name\": \"Pat\",\n  \"last_name\": \"Ient\",\n  \"dob\": \"2000-01-01\",\n  \"gender\": \"M\",\n  \"nickname\": \"patty\",\n  \"ailment_ids\": [2]\n}"
        }
      }
    },
    {
      "name": "2. Signup Doctor",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/auth/signup/doctor",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{doctor_email}}\",\n  \"password\": \"{{password}}\",\n  \"first_name\": \"Doc\",\n  \"last_name\": \"Tor\",\n  \"dob\": \"1980-01-01\",\n  \"gender\": \"F\",\n  \"qualification\": \"MBBS\",\n  \"bio\": \"Speech therapy expert\"\n}"
        }
      }
    },
    {
      "name": "3. Login (Patient) - saves token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token', json.access_token);",
              "console.log('Saved patient token');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/login",
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "username", "value": "{{patient_email}}" },
            { "key": "password", "value": "{{password}}" }
          ]
        }
      }
    },
    {
      "name": "4. Login (Doctor) - saves doctor_token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('doctor_token', json.access_token);",
              "console.log('Saved doctor token');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/login",
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "username", "value": "{{doctor_email}}" },
            { "key": "password", "value": "{{password}}" }
          ]
        }
      }
    },
    {
      "name": "5. Get Me",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
        "url": "{{base_url}}/auth/me"
      }
    },
    {
      "name": "6. List Phrases",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
        "url": "{{base_url}}/phrases?difficulty=EASY&limit=10"
      }
    },
    {
      "name": "7. Create Phrase (Doctor only)",
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{doctor_token}}" }] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/phrases",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sentence\": \"A brand new practice sentence.\",\n  \"ailment_id\": 2,\n  \"difficulty\": \"MEDIUM\"\n}"
        }
      }
    },
    {
      "name": "8. Game Phrases (Patient)",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
        "url": "{{base_url}}/game/phrases?difficulty=EASY&count=5"
      }
    },
    {
      "name": "9. Proficiency Start - builds submit body",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('test_id', json.test_id);",
              "var responses = json.phrases.map(function(p){ return { phrase_id: p.id, score: 0.9 }; });",
              "pm.collectionVariables.set('prof_responses', JSON.stringify({ responses: responses }));",
              "console.log('Saved test_id ' + json.test_id + ' and ' + responses.length + ' responses');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
        "url": "{{base_url}}/proficiency-test/start"
      }
    },
    {
      "name": "10. Proficiency Submit",
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/proficiency-test/{{test_id}}/submit",
        "body": { "mode": "raw", "raw": "{{prof_responses}}" }
      }
    }
  ]
}
